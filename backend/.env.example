# Preferred: separate fields (plain password; @ and special chars are OK). Save this file as UTF-8.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=student_connect

# Optional legacy single URL (must be UTF-8; encode @ in password as %40). Not needed if POSTGRES_PASSWORD is set.
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/student_connect

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRE_MINUTES=10080
